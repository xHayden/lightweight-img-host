doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(http-equiv="X-UA-Compatible", content="IE=edge")
    meta(name="viewport", content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0")
    title File Upload
    link(href="/styles/style.css", rel="stylesheet")

  body.light-theme
    div(style="max-width: 520px; margin: 0 auto; padding: 4rem 1.5rem;")

      //- Header
      div.animate-fade-up(style="margin-bottom: 2.5rem;")
        h1.display-font(style="font-size: 2.5rem; font-weight: 400; margin: 0; letter-spacing: -0.01em;") Upload
        p(style="color: var(--text-muted); font-size: 0.85rem; margin-top: 0.35rem;") Drop a file below to host it.

      //- Form
      form#upload-form(action="/upload" enctype="multipart/form-data" method="post")

        //- Drop zone
        div.animate-fade-up.stagger-1
          div#drop-zone.light-drop-zone
            svg(width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-faint); margin-bottom: 0.5rem;")
              path(d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4")
              polyline(points="17 8 12 3 7 8")
              line(x1="12" y1="3" x2="12" y2="15")
            p(style="color: var(--text-muted); font-size: 0.85rem;") Drag & drop a file here, or click to browse
            p#file-name.file-name No file selected
            input#file-input(type="file" name="file-uploaded" style="display:none")

        //- Custom name
        div.animate-fade-up.stagger-2(style="margin-top: 1.25rem; display: flex; align-items: center; gap: 0.6rem;")
          label(for="custom-key" style="color: var(--text-muted); font-size: 0.8rem; white-space: nowrap;") Custom name
          input#custom-key.light-input(type="text" name="custom-key" placeholder="e.g. cat" style="flex: 1; max-width: 200px;" autocomplete="off")
          span(style="color: var(--text-faint); font-size: 0.7rem;") optional

        //- Limit note
        p.animate-fade-up.stagger-3(style="color: var(--text-faint); font-size: 0.7rem; margin-top: 0.75rem;") Max 100 MB — images, videos, PDFs, and more.

        //- Submit
        div.animate-fade-up.stagger-4(style="margin-top: 1.5rem;")
          input.light-btn(type="submit" value="Upload")

  script(src="/js/upload.js")
