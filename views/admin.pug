doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(http-equiv="X-UA-Compatible", content="IE=edge")
    meta(name="viewport", content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0")
    title Admin Panel
    link(href="/styles/style.css", rel="stylesheet")

  body.light-theme
    div(style="max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem;")

      //- Header
      div.animate-fade-up(style="display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 2rem;")
        div
          h1.display-font(style="font-size: 2.75rem; font-weight: 400; margin: 0; letter-spacing: -0.01em;") Your Files
          p(style="color: var(--text-muted); font-size: 0.8rem; margin-top: 0.25rem;") #{user.name}
        a.light-btn(href="/logout" style="font-size: 0.8rem; padding: 0.4rem 1rem;") Sign out

      hr.light-divider.animate-fade-in

      //- Toolbar
      div.animate-fade-up.stagger-1(style="display: flex; align-items: center; justify-content: space-between; margin: 1.5rem 0;")
        p(style="font-size: 0.85rem; color: var(--text-muted);")
          span(style="font-weight: 500; color: var(--text);") #{totalFiles}
          span  files
        a.light-btn-solid(href="/upload" style="font-size: 0.8rem; padding: 0.4rem 1rem;") Upload

      //- File grid
      if uploads.length === 0 && page === 1
        div.animate-fade-up.stagger-2(style="text-align: center; padding: 4rem 0;")
          p(style="color: var(--text-faint); font-size: 0.9rem;") No files uploaded yet.
      else
        div.light-file-grid.animate-fade-up.stagger-2
          each file, i in uploads
            div.light-file-card(data-filename=file.name data-url=file.url)
              a(href=file.url target="_blank" style="text-decoration: none;")
                - var ext = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();
                - var isImage = ['.jpg', '.jpeg', '.png', '.gif', '.webp', '.svg'].indexOf(ext) !== -1;
                if isImage
                  img(src=file.url alt=file.name loading="lazy")
                else
                  div.placeholder= ext || 'file'
              button.action-btn.rename-btn &#9998;
              button.action-btn.delete-btn &times;
              div.info
                div.name(title=file.name)= file.name
                div.meta
                  span= file.size ? (file.size > 1048576 ? (file.size / 1048576).toFixed(1) + ' MB' : (file.size / 1024).toFixed(0) + ' KB') : ''

        //- Pagination
        if totalPages > 1
          div.animate-fade-up.stagger-3(style="display: flex; justify-content: center; margin-top: 2rem;")
            div.light-pagination
              if page > 1
                a(href="/admin?page=" + (page - 1)) &laquo; Prev
              - for (var i = 1; i <= totalPages; i++)
                if i === page
                  span.current= i
                else
                  a(href="/admin?page=" + i)= i
              if page < totalPages
                a(href="/admin?page=" + (page + 1)) Next &raquo;

  script(src="/js/admin.js")
